{
  "expo": {
    "name": "mobile_app",
    "slug": "mobile_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.batuhan.planthealth",
      "supportsTablet": true
    },
    "android": {
      "package": "com.batuhan.planthealth",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "PlantHealth, bitki türünüzü tanımak ve hastalıkları yapay zeka ile teşhis edebilmek için kameranıza erişim iznine ihtiyaç duyar.",
          "microphonePermission": "PlantHealth videolar için mikrofona ihtiyaç duyar."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PlantHealth, daha önce galerinizde kayıtlı olan bir bitki yaprağı fotoğrafını analiz edebilmek için fotoğraf kitaplığınıza erişim talep eder."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}